# ===========================================
# Mystasis Backend Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values.
# DO NOT commit .env to version control.

# Database Configuration
# ----------------------
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
#
# For local development:
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD_HERE@localhost:5432/mystasis_db?schema=public"
#
# For production, use a secure connection string from your database provider.
# Consider enabling SSL: ?sslmode=require

# Connection pool settings (optional, for Prisma)
# Minimum connections to keep open
DATABASE_POOL_MIN=1
# Maximum connections in the pool
DATABASE_POOL_MAX=10

# Application Configuration
# -------------------------
# Environment mode: development, test, production
NODE_ENV=development

# Port for the HTTP server (default: 3000)
PORT=3000

# JWT Configuration (required for authentication)
# ------------------------------------------------
# Secret key for signing JWT tokens - use a strong random string in production
# Generate one with: openssl rand -base64 32
# JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Token expiration time (e.g., 1h, 7d, 30d)
# JWT_EXPIRATION=7d

# LLM Integration (required for AI features)
# ------------------------------------------
# URL for the LLM API service
# LLM_API_URL=https://api.example.com/llm

# API key for LLM service authentication
# LLM_API_KEY=your-llm-api-key

# Timeout in milliseconds for LLM requests
# LLM_TIMEOUT_MS=30000

# LLM Rate Limiting (per-user, protects API costs)
# -------------------------------------------------
# Summary endpoint: expensive LLM call for clinicians
# THROTTLE_LLM_SUMMARY_LIMIT=5
# THROTTLE_LLM_SUMMARY_TTL=3600
# Nudge endpoint: lighter LLM call for patients
# THROTTLE_LLM_NUDGE_LIMIT=10
# THROTTLE_LLM_NUDGE_TTL=3600

# Logging Configuration
# ---------------------
# Log level: error, warn, log, debug, verbose
# LOG_LEVEL=log

# CORS Configuration
# ------------------
# Allowed origins for CORS (comma-separated)
# CORS_ORIGINS=http://localhost:3000,http://localhost:4200
