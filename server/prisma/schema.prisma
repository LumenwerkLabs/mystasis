// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// User model with role-based access
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String?
  lastName  String?
  birthdate DateTime
  role      UserRole @default(PATIENT)
  clinicId           String?
  shareWithClinician Boolean  @default(true)
  anonymousResearch  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  clinic               Clinic?          @relation(fields: [clinicId], references: [id])
  biomarkerValues      BiomarkerValue[]
  alerts               Alert[]
  summaries            LLMSummary[]
  refreshTokens        RefreshToken[]
  patientAnamneses     Anamnesis[]      @relation("PatientAnamneses")
  clinicianAnamneses   Anamnesis[]      @relation("ClinicianAnamneses")

  @@index([email])
  @@index([role])
  @@index([clinicId])
}

// Refresh tokens for session management (token rotation)
model RefreshToken {
  id         String    @id @default(uuid())
  token      String    @unique
  userId     String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  replacedBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

// Blacklisted access tokens (revoked before natural expiry)
model BlacklistedToken {
  id        String   @id @default(uuid())
  jti       String   @unique
  userId    String
  expiresAt DateTime
  reason    String?
  createdAt DateTime @default(now())

  @@index([jti])
  @@index([expiresAt])
}

// Biomarker timeseries data
model BiomarkerValue {
  id        String        @id @default(uuid())
  userId    String
  type      BiomarkerType
  value     Float
  unit      String
  timestamp DateTime
  source    String?       // e.g., "apple_health", "lab_upload", "manual"
  metadata  Json?
  createdAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([timestamp])
  @@index([userId, type, timestamp])
}

// Alert model for biomarker threshold violations
model Alert {
  id        String        @id @default(uuid())
  userId    String
  type      BiomarkerType
  severity  AlertSeverity
  status    AlertStatus   @default(ACTIVE)
  title     String
  message   String
  value     Float?
  threshold Float?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
}

// LLM-generated summaries and insights
model LLMSummary {
  id            String      @id @default(uuid())
  userId        String
  type          SummaryType
  content       String
  structuredData Json?      // For structured flags and recommendations
  audienceRole  UserRole    // PATIENT or CLINICIAN facing
  modelVersion  String?     // Track which LLM version generated this
  promptHash    String?     // For reproducibility
  createdAt     DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// Enums
enum UserRole {
  PATIENT
  CLINICIAN
}

