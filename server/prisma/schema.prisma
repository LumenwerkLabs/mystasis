enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

enum SummaryType {
  DAILY_RECAP
  WEEKLY_SUMMARY
  TREND_ANALYSIS
  RISK_ASSESSMENT
  WELLNESS_NUDGE
  CLINICIAN_REPORT
}

// Structured clinical anamnesis from voice-transcribed consultations
model Anamnesis {
  id                      String    @id @default(uuid())
  patientId               String
  clinicianId             String
  rawTranscript           String
  chiefComplaint          String
  historyOfPresentIllness String
  pastMedicalHistory      String[]
  currentMedications      String[]
  allergies               String[]
  familyHistory           String[]
  reviewOfSystems         String[]
  socialHistory           String[]
  isReviewed              Boolean   @default(false)
  recordedAt              DateTime
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime? // Soft-delete for HIPAA retention compliance

  patient   User @relation("PatientAnamneses", fields: [patientId], references: [id], onDelete: Cascade)
  clinician User @relation("ClinicianAnamneses", fields: [clinicianId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([clinicianId])
  @@index([recordedAt])
  @@index([patientId, recordedAt])
  @@index([deletedAt])
}

// Clinic model for multi-tenancy
model Clinic {
  id        String   @id @default(uuid())
  name      String
  address   String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@index([name])
}

// HIPAA-compliant audit log for PHI access and consent changes.
// No FK to User — audit logs must survive user deletion per HIPAA retention.
// IMPORTANT: Consider adding database-level row security policies to prevent
// UPDATE/DELETE on this table for HIPAA immutability requirements.
model AuditLog {
  id           String   @id @default(uuid())
  userId       String
  action       String   // e.g., "PHI_ACCESS", "CONSENT_CHANGE", "PASSWORD_VERIFY"
  resourceType String   // e.g., "BiomarkerValue", "Alert", "Anamnesis", "User"
  resourceId   String?  // ID of the accessed resource (nullable for list endpoints)
  metadata     Json?    // Non-PHI context: { method, path, statusCode }
  ipAddress    String?
  userAgent    String?
  timestamp    DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resourceType])
  @@index([timestamp])
  @@index([userId, timestamp])
}
