// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model with role-based access
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String?
  lastName  String?
  birthdate DateTime
  role      UserRole @default(PATIENT)
  clinicId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic          Clinic?          @relation(fields: [clinicId], references: [id])
  biomarkerValues BiomarkerValue[]
  alerts          Alert[]
  summaries       LLMSummary[]

  @@index([email])
  @@index([role])
  @@index([clinicId])
}

// Biomarker timeseries data
model BiomarkerValue {
  id        String        @id @default(uuid())
  userId    String
  type      BiomarkerType
  value     Float
  unit      String
  timestamp DateTime
  source    String?       // e.g., "apple_health", "lab_upload", "manual"
  metadata  Json?
  createdAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([timestamp])
  @@index([userId, type, timestamp])
}

// Alert model for biomarker threshold violations
model Alert {
  id        String        @id @default(uuid())
  userId    String
  type      BiomarkerType
  severity  AlertSeverity
  status    AlertStatus   @default(ACTIVE)
  title     String
  message   String
  value     Float?
  threshold Float?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
}

// LLM-generated summaries and insights
model LLMSummary {
  id            String      @id @default(uuid())
  userId        String
  type          SummaryType
  content       String
  structuredData Json?      // For structured flags and recommendations
  audienceRole  UserRole    // PATIENT or CLINICIAN facing
  modelVersion  String?     // Track which LLM version generated this
  promptHash    String?     // For reproducibility
  createdAt     DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// Enums
enum UserRole {
  PATIENT
  CLINICIAN
}

enum BiomarkerType {
  // Cardiovascular
  HEART_RATE
  HEART_RATE_VARIABILITY
  BLOOD_PRESSURE_SYSTOLIC
  BLOOD_PRESSURE_DIASTOLIC
  RESTING_HEART_RATE
  WALKING_HEART_RATE

  // Vitals
  BLOOD_OXYGEN
  RESPIRATORY_RATE
  BODY_TEMPERATURE
  PERIPHERAL_PERFUSION_INDEX

  // Metabolic
  GLUCOSE
  HBA1C
  CHOLESTEROL_TOTAL
  CHOLESTEROL_LDL
  CHOLESTEROL_HDL
  TRIGLYCERIDES

  // Fitness
  STEPS
  ACTIVE_CALORIES
  BASAL_CALORIES
  SLEEP_DURATION
  SLEEP_QUALITY
  SLEEP_DEEP
  SLEEP_REM
  SLEEP_LIGHT
  SLEEP_AWAKE
  VO2_MAX
  EXERCISE_TIME
  DISTANCE_WALKING_RUNNING
  DISTANCE_SWIMMING
  DISTANCE_CYCLING
  FLIGHTS_CLIMBED

  // Body composition
  WEIGHT
  BMI
  BODY_FAT_PERCENTAGE
  HEIGHT
  WAIST_CIRCUMFERENCE

  // Hydration
  WATER_INTAKE

  // Pulmonary
  FORCED_EXPIRATORY_VOLUME

  // Cardiac diagnostics
  ELECTRODERMAL_ACTIVITY
  ATRIAL_FIBRILLATION_BURDEN

  // Blood markers
  VITAMIN_D
  IRON
  FERRITIN
  B12
  FOLATE

  // Inflammation
  CRP
  ESR

  // Hormones
  TESTOSTERONE
  CORTISOL
  TSH
  T3
  T4

  // HRV alternative
  HEART_RATE_VARIABILITY_RMSSD

  // Diabetes management
  INSULIN_DELIVERY

  // Wellness
  MINDFULNESS

  // Sleep
  SLEEP_IN_BED

  // Nutrition - Macronutrients
  DIETARY_ENERGY_CONSUMED
  DIETARY_CARBS_CONSUMED
  DIETARY_PROTEIN_CONSUMED
  DIETARY_FATS_CONSUMED
  DIETARY_FIBER
  DIETARY_SUGAR
  DIETARY_CAFFEINE
  DIETARY_FAT_SATURATED
  DIETARY_FAT_MONOUNSATURATED
  DIETARY_FAT_POLYUNSATURATED
  DIETARY_CHOLESTEROL

  // Nutrition - Vitamins
  DIETARY_VITAMIN_A
  DIETARY_VITAMIN_C
  DIETARY_VITAMIN_D
  DIETARY_VITAMIN_E
  DIETARY_VITAMIN_K
  DIETARY_THIAMIN
  DIETARY_RIBOFLAVIN
  DIETARY_NIACIN
  DIETARY_PANTOTHENIC_ACID
  DIETARY_VITAMIN_B6
  DIETARY_BIOTIN
  DIETARY_VITAMIN_B12
  DIETARY_FOLATE

  // Nutrition - Minerals
  DIETARY_CALCIUM
  DIETARY_IRON
  DIETARY_MAGNESIUM
  DIETARY_PHOSPHORUS
  DIETARY_POTASSIUM
  DIETARY_SODIUM
  DIETARY_ZINC
  DIETARY_CHROMIUM
  DIETARY_COPPER
  DIETARY_IODINE
  DIETARY_MANGANESE
  DIETARY_MOLYBDENUM
  DIETARY_SELENIUM

  // Other
  CUSTOM
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

enum SummaryType {
  DAILY_RECAP
  WEEKLY_SUMMARY
  TREND_ANALYSIS
  RISK_ASSESSMENT
  WELLNESS_NUDGE
  CLINICIAN_REPORT
}

// Clinic model for multi-tenancy
model Clinic {
  id        String   @id @default(uuid())
  name      String
  address   String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@index([name])
}
